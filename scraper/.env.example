# Optimi Scraper Backend Environment Variables

# Required for AI Assistant endpoint
OPENAI_API_KEY=sk-your-key-here

# ---------------------------------------------------------------------------
# Optional: Social Media APIs (for reliable extraction without scraping)
# ---------------------------------------------------------------------------

# Twitter / X API v2 — Bearer Token
# Get one at: https://developer.twitter.com/en/portal/dashboard
# Free tier: 500 tweets/month read limit
# Basic tier: $100/month, 10,000 tweets/month
# TWITTER_BEARER_TOKEN=

# Product Hunt API — Developer Token
# Get one at: https://www.producthunt.com/v2/oauth/applications
# PRODUCT_HUNT_TOKEN=
